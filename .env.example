# Copy to .env.local and fill with your Firebase web app config.
# Contact form submissions are stored in Firestore collection: inquiries
# Firestore rules should allow create-only from clients if you enable this.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
